--- User & Group ID ---

Use 'id -u' and 'id -g' on your host to find these

PUID=1000
PGID=1000

--- Server Identity ---

SERVER_NAME=dedicated
ADMIN_USERNAME=admin

IMPORTANT: Change these passwords!

PASSWORD=CHANGEME
ADMIN_PASSWORD=CHANGEME
RCON_PASSWORD=CHANGEME

--- Network Settings ---

DEFAULT_PORT=16261
RCON_PORT=27015

--- Resource Management ---

Memory in GB

MEMORY_XMX_GB=8

--- Game Version ---

Leave empty for Stable, or use "unstable" for Build 42

SERVER_BRANCH=unstable

--- Logic ---

UPDATE_ON_START=true

--- Settings Patching ---

PVP=true
MAX_PLAYERS=32
ALLOW_MINIMAP=true

--- Advanced ---

Add extra startup flags here if needed

EXTRA_FLAGS=