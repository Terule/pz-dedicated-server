# --- Project Zomboid Server Configuration ---
SERVER_NAME=dedicated
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME

# --- Access Control ---
# Leave SERVER_PASSWORD empty for a public server with no password
SERVER_PASSWORD=
# Set to "true" to show the server in the public global list
PUBLIC=false

# --- RCON & Ports ---
RCON_PASSWORD=CHANGEME
RCON_PORT=27015
DEFAULT_PORT=16261

# --- Performance ---
# Memory in GB (e.g., 8, 16)
MEMORY_XMX_GB=8

# --- Game Version & Protection ---
# Options:
# - Leave empty for Stable (Build 41)
# - Use "unstable" for the latest Build 42 (42.16+)
# - Use "outdatedunstable" for Build 42.15 (Legacy B42)
SERVER_BRANCH=outdatedunstable

# --- Auto Update ---
# If SERVER_BRANCH is "outdatedunstable", this will be forced to "false" 
# by the entrypoint to protect your save files from B42.16+ corruption.
UPDATE_ON_START=true

# --- Permissions ---
# Run "id" in your terminal to find your UID and GID
PUID=1000
PGID=1000

# --- Game Settings ---
PVP=false
MAX_PLAYERS=10
ALLOW_MINIMAP=true

# --- Privacy & Display (ini) ---
MOUSE_OVER_DISPLAY_NAME=false
DISPLAY_USER_NAME=false
SHOW_FIRST_LAST_NAME=true
SNEAK_HIDE_PLAYERS=false
MAP_REMOTE_VISIBILITY=3

# --- Sandbox Settings (SandboxVars.lua) ---
ALLOW_MINIMAP=true